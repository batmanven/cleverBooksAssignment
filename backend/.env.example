# Server
PORT=5001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/cleverbooks

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Reconciliation Scheduler (cron expression — default 2:00 AM IST)
RECONCILIATION_CRON=0 2 * * *

# Webhook.site URL for notifications
WEBHOOK_URL=https://webhook.site/your-unique-id

# Rate Limiting
UPLOAD_RATE_LIMIT_WINDOW_MS=60000
UPLOAD_RATE_LIMIT_MAX=5
